#!/bin/bash -e

# This script uses gum for interaction and can optionally emit
# an export line suitable for eval to set KUBECONFIG in the caller shell.

EMIT_EXPORT=false

while [[ $# -gt 0 ]]; do
  case "$1" in
  --export)
    EMIT_EXPORT=true
    shift
    ;;
  --help | -h)
    echo "Usage: $(basename "$0") [--export]"
    echo "  --export   Emit 'export KUBECONFIG=…' to stdout (for eval)"
    exit 0
    ;;
  *)
    echo "Unknown option: $1" >&2
    exit 1
    ;;
  esac
done

log() {
  if $EMIT_EXPORT; then
    # When emitting export, send informational logs to stderr
    echo "$*" >&2
  else
    echo "$*"
  fi
}

fetch_gateway() {
  export KUBECONFIG="$kubeconfig"
  gcloud container fleet memberships \
    get-credentials "$CONTAINER_CLUSTER" --project "$PROJECT"
}

fetch_direct() {
  export KUBECONFIG="$kubeconfig"
  # Determine the region/zone for the cluster
  LOCATION=$(gcloud container clusters list --project "$PROJECT" --filter="name=$CONTAINER_CLUSTER" --format="value(location)")
  if [ -z "$LOCATION" ]; then
    log "Could not determine location for cluster $CONTAINER_CLUSTER"
    exit 1
  fi
  gcloud container clusters get-credentials "$CONTAINER_CLUSTER" --region "$LOCATION" --project "$PROJECT"
}

#WARNING:
# Select provider using gum
PROVIDER=$(gum choose --header "Select provider" "GCP (GKE)" "AWS (EKS)")
if [ -z "$PROVIDER" ]; then
  log "No provider selected. Exiting..."
  exit 1
fi

if [[ "$PROVIDER" == "GCP"* ]]; then
  PROJECT=$(gum choose --header "Select GCP project" $(cat "$(dirname "$0")/projects-gcp" | sort))
  if [ -z "$PROJECT" ]; then
    log "No project selected. Exiting..."
    exit 1
  fi
  DIR="$HOME/.kube/configs/$PROJECT"
  mkdir -p "$DIR"
  readarray -t MEMBERSHIPS < <(gcloud container fleet memberships list --project "$PROJECT" | awk 'NR>1 {print $1}')
  if [ ${#MEMBERSHIPS[@]} -eq 0 ]; then
    log "No fleet memberships found for project $PROJECT. Exiting..."
    exit 1
  fi
  CONTAINER_CLUSTER=$(gum choose --header "Select cluster" "${MEMBERSHIPS[@]}")
  if [ -z "$CONTAINER_CLUSTER" ]; then
    log "No cluster selected. Exiting..."
    exit 1
  fi
  kubeconfig="$DIR/$CONTAINER_CLUSTER"
  log "$kubeconfig"
  CONNECTION_METHOD=$(gum choose --header "Select connection method" \
    "Connect Gateway (fleet memberships) - most commands work" \
    "Direct (requires network access) - all commands work including exec")
  if [ -z "$CONNECTION_METHOD" ]; then
    log "No connection method selected. Exiting..."
    exit 1
  fi
  if [ -f "$kubeconfig" ]; then
    if gum confirm "Kubeconfig file $kubeconfig already exists. Overwrite?"; then
      log "Overwriting..."
      if [[ "$CONNECTION_METHOD" == "Connect Gateway"* ]]; then
        fetch_gateway
      else
        fetch_direct
      fi
    else
      log "Exiting..."
      exit 1
    fi
  else
    if [[ "$CONNECTION_METHOD" == "Connect Gateway"* ]]; then
      fetch_gateway
    else
      fetch_direct
    fi
  fi
elif [[ "$PROVIDER" == "AWS"* ]]; then
  CLUSTER_NAME=$(gum choose --header "Select AWS EKS cluster" $(cat "$(dirname "$0")/projects-aws" | grep -v '^#' | grep -v '^$'))
  if [ -z "$CLUSTER_NAME" ]; then
    log "No cluster selected. Exiting..."
    exit 1
  fi
  DIR="$HOME/.kube/configs/$CLUSTER_NAME"
  mkdir -p "$DIR"
  kubeconfig="$DIR/$CLUSTER_NAME"
  log "$kubeconfig"
  if [ -f "$kubeconfig" ]; then
    if gum confirm "Kubeconfig file $kubeconfig already exists. Overwrite?"; then
      log "Overwriting..."
      aws eks update-kubeconfig --region "ap-northeast-1" --name "$CLUSTER_NAME" --kubeconfig "$kubeconfig"
    else
      log "Exiting..."
      exit 1
    fi
  else
    aws eks update-kubeconfig --region "ap-northeast-1" --name "$CLUSTER_NAME" --kubeconfig "$kubeconfig"
  fi
else
  log "Unknown provider. Exiting..."
  exit 1
fi

if $EMIT_EXPORT; then
  echo "export KUBECONFIG=\"$kubeconfig\""
else
  ls -halt "$DIR"
  echo "$KUBECONFIG"
fi
