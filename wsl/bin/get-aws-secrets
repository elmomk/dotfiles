#!/usr/bin/env bash

# Check if gum is installed
if ! command -v gum &>/dev/null; then
  echo "Error: 'gum' is not installed. Install it via 'brew install gum' or 'go install github.com/charmbracelet/gum@latest'"
  exit 1
fi

# 1. Fetch the list of secret names
echo "Fetching secrets from AWS..."
SECRETS=$(aws secretsmanager list-secrets --query 'SecretList[*].Name' --output text | tr '\t' '\n')

if [ -z "$SECRETS" ]; then
  gum style --foreground 210 "No secrets found in this AWS account/region."
  exit 1
fi

# 2. Use gum filter to select a secret
SELECTED_SECRET=$(echo "$SECRETS" | gum filter --placeholder "Search for a secret...")

# Exit if user cancels (ESC)
[ -z "$SELECTED_SECRET" ] && exit 0

# 3. Retrieve the secret value
gum spin --spinner dot --title "Retrieving $SELECTED_SECRET..." -- \
  aws secretsmanager get-secret-value --secret-id "$SELECTED_SECRET" --query 'SecretString' --output text >.tmp_secret.json

# 4. Ask user how they want to view the data
ACTION=$(gum choose "View Full JSON" "Get Specific Key" "Copy to Clipboard" "cat to stdout" "Cancel")

case $ACTION in
"View Full JSON")
  gum pager <.tmp_secret.json
  ;;
"Get Specific Key")
  # Extract keys from JSON to let user pick one
  KEY=$(cat .tmp_secret.json | jq -r 'keys[]' | gum filter --placeholder "Select key...")
  if [ -n "$KEY" ]; then
    VALUE=$(cat .tmp_secret.json | jq -r ".$KEY")
    gum style --foreground 82 "Value for $KEY:"
    echo "$VALUE"

    if gum confirm "Copy value to clipboard?"; then
      echo -n "$VALUE" | pbcopy # Use 'xclip -sel clip' for Linux
      echo "Copied!"
    fi
  fi
  ;;
"Copy to Clipboard")
  cat .tmp_secret.json | pbcopy
  echo "Full JSON copied to clipboard."
  ;;
"cat to stdout")
  cat .tmp_secret.json
  ;;
esac

# Cleanup
rm .tmp_secret.json
