#!/bin/bash

#WARNING:
# Select EKS cluster using gum from projects-aws file
CLUSTER_NAME=$(gum choose --header "Select AWS EKS cluster" $(cat "$(dirname "$0")/projects-aws" | grep -v '^#' | grep -v '^$'))
if [ -z "$CLUSTER_NAME" ]; then
	echo "No cluster selected. Exiting..."
	exit 1
fi

aws eks update-kubeconfig --region "ap-northeast-1" --name "$CLUSTER_NAME" --kubeconfig "$HOME/.kube/configs/$CLUSTER_NAME/$CLUSTER_NAME"
