#!/bin/bash

# 1. Fetch all repository names
# We use spin to show activity while AWS fetches the list
REPOS=$(gum spin --title "Fetching repositories..." -- aws ecr describe-repositories --query 'repositories[*].repositoryName' --output text | tr '\t' '\n')

if [ -z "$REPOS" ]; then
  gum style --foreground 196 "No repositories found."
  exit 1
fi

# 2. Use Gum Filter for a searchable list
# 'gum filter' is the correct command for search/fuzzy-find
SELECTED_REPO=$(echo "$REPOS" | gum filter --placeholder "Search for a repository..." --header "ECR Repositories")

# Exit if user cancels (Esc/Ctrl+C)
if [ -z "$SELECTED_REPO" ]; then
  echo "No repository selected. Exiting."
  exit 0
fi

gum style --foreground 212 "Selected: $SELECTED_REPO"
echo "------------------------------------------------"

# 3. List images for the selected repository
# Shows Tag and Push Date in a clean table
aws ecr describe-images --repository-name "$SELECTED_REPO" \
  --query 'sort_by(imageDetails,& imagePushedAt)[*].{Tag:imageTags[0], Pushed:imagePushedAt}' \
  --output table

