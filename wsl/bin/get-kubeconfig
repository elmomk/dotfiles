#!/bin/bash -e

fetch() {
  export KUBECONFIG=$kubeconfig
  gcloud container fleet memberships \
    get-credentials $CONTAINER_CLUSTER --project $PROJECT

}

#WARNING:
PROJECT=$(cat "$(dirname "$0")/projects" | sort | fzf --prompt="Enter project: " --height=5)

# create directory if not exists
DIR=~/.kube/configs/$PROJECT
if [ ! -d "$DIR" ]; then
  mkdir -p $DIR
fi

CONTAINER_CLUSTER=$(gcloud container fleet memberships list --project $PROJECT |
  awk '{print $1}' | grep -v NAME | fzf --prompt="Enter cluster: " --height=10)

kubeconfig=$DIR/$CONTAINER_CLUSTER
echo $kubeconfig
# check if file exists, if so ask to overwrite
if [ -f "$kubeconfig" ]; then
  read -p "Kubeconfig file $kubeconfig already exists. Overwrite? (y/n) " choice
  case "$choice" in
  y | Y)
    echo "Overwriting..."
    fetch
    ;;
  n | N)
    echo "Exiting..."
    exit 1
    ;;
  *)
    echo "Invalid choice. Exiting..."
    exit 1
    ;;
  esac
else
  fetch
fi

ls -halt $DIR
echo $KUBECONFIG
