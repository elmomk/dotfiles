#!/bin/bash

# ==========================================
# WSL MONITOR (Verbose Daemon Version)
# Checks: C: Drive, WSL Disk, Dotfiles
# ==========================================

# Configuration
THRESHOLD_PERCENT=60
DOTFILES_DIR="$HOME/dotfiles"

# Helper: Send Windows Notification
notify_windows() {
  local title="$1"
  local message="$2"
  echo "  -> TRIGGERING NOTIFICATION: $title - $message"
  /mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -Command "& {
        [reflection.assembly]::loadwithpartialname('System.Windows.Forms') | Out-Null;
        \$obj = New-Object System.Windows.Forms.NotifyIcon;
        \$obj.Icon = [System.Drawing.SystemIcons]::Warning;
        \$obj.BalloonTipIcon = 'Warning';
        \$obj.BalloonTipText = '$message';
        \$obj.BalloonTipTitle = '$title';
        \$obj.Visible = \$true;
        \$obj.ShowBalloonTip(5000);
    }"
}

echo "--- Monitor Run Started: $(date) ---"

# 1. Check Windows C: Drive
C_USAGE=$(df -h /mnt/c | awk 'NR==2 {print $5}' | sed 's/%//')
echo "C: Drive Usage: ${C_USAGE}% (Threshold: ${THRESHOLD_PERCENT}%)"

if [ "$C_USAGE" -ge "$THRESHOLD_PERCENT" ]; then
  notify_windows "Storage Critical" "Windows C: Drive is ${C_USAGE}% full."
fi
#
# 1. Check Windows D: Drive
D_USAGE=$(df -h /mnt/d | awk 'NR==2 {print $5}' | sed 's/%//')
echo "D: Drive Usage: ${D_USAGE}% (Threshold: ${THRESHOLD_PERCENT}%)"

if [ "$D_USAGE" -ge "$THRESHOLD_PERCENT" ]; then
  notify_windows "Storage Critical" "Windows D: Drive is ${C_USAGE}% full."
fi

# 2. Check WSL Virtual Disk
WSL_USAGE=$(df -h / | awk 'NR==2 {print $5}' | sed 's/%//')
echo "WSL Disk Usage: ${WSL_USAGE}% (Threshold: ${THRESHOLD_PERCENT}%)"

if [ "$WSL_USAGE" -ge "$THRESHOLD_PERCENT" ]; then
  notify_windows "Storage Critical" "WSL Internal Disk is ${WSL_USAGE}% full."
fi

# 3. Check Dotfiles
if [ -d "$DOTFILES_DIR" ]; then
  # Git status check
  CHANGES=$(git -C "$DOTFILES_DIR" status --porcelain)
  if [ -n "$CHANGES" ]; then
    COUNT=$(echo "$CHANGES" | grep -c '^')
    echo "Dotfiles Status: DIRTY ($COUNT uncommitted files)"
    notify_windows "Dotfiles Dirty" "You have $COUNT uncommitted changes."
  else
    echo "Dotfiles Status: CLEAN"
  fi
else
  echo "Dotfiles Directory not found at $DOTFILES_DIR"
fi

echo "--- Monitor Run Finished ---"
