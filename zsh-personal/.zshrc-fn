    tmux attach -t `tls | awk -F':' '{print $1}' | head -n1`
}

wttr () {
    echo "checking weather"
    if [[ -z $1 ]]; then
        curl  wttr.in/Tervuren
    else
        curl  wttr.in/$1
    fi
}


enter () {
    if [[ $(distrobox list |grep $(date +%Y%m) 2> /dev/null) ]];
    then
        DISTROBOX=$(distrobox list|grep $(date +%Y%m) 2> /dev/null | awk '{print $3}')
        echo "entering distrobox $DISTROBOX"
        distrobox enter "$DISTROBOX"
    else
        echo "create a new monthly toolbox"
        newdistro
        enter
    fi
}


# worktrees
bra() {
    # 1. Select the target worktree path
    local BRANCH
    BRANCH=$(git worktree list | awk '{print $1}' | fzf --cycle --preview 'cd {1}; git show --color=always')

    # Exit if no selection
    if [[ -z "$BRANCH" ]]; then
        echo "No branch selected"
        return 1
    fi

    echo "Target Branch Root: $BRANCH"

    # 2. Get current path relative to the CURRENT Git root
    # This grabs the root of where you are NOW (e.g., /home/user/repo)
    local CURRENT_GIT_ROOT
    CURRENT_GIT_ROOT=$(git rev-parse --show-toplevel)
    
    # This strips the root prefix from PWD to get the sub-path (e.g., /infra/prod...)
    local RELATIVE_PATH="${PWD#$CURRENT_GIT_ROOT}"

    # 3. Construct the proposed destination
    local DESTINATION="${BRANCH}${RELATIVE_PATH}"

    # 4. Check if the directory exists in the target worktree
    if [[ -d "$DESTINATION" ]]; then
        echo "Mirroring path: $RELATIVE_PATH"
        cd "$DESTINATION"
    else
        echo "Path '${RELATIVE_PATH}' does not exist in target."
        echo "Fallback to root: $BRANCH"
        cd "$BRANCH"
    fi
}
