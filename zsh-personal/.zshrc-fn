worktree-clean() {
git worktree list --porcelain | grep '^worktree ' | cut -d ' ' -f 2 | xargs -I {} sh -c 'MAIN=$(git rev-parse --show-toplevel); if [ "{}" != "$MAIN" ]; then cd {}; if [ -z "$(git status --porcelain)" ]; then echo "🧹 Removing: {}"; git worktree remove "{}"; else echo "❌ DIRTY: {}"; fi; fi'
}

worktree-check() {
  git worktree list --porcelain | grep '^worktree ' | cut -d ' ' -f 2 | xargs -I {} sh -c 'cd {}; if [ -n "$(git status --porcelain)" ]; then echo "❌ DIRTY: {}"; else echo "✅ CLEAN: {}"; fi'
}
decrypt() {
    cd $(git rev-parse --show-toplevel) || return 1
    git secret reveal -vfF
    cd -
}

encrypt(){
    cd $(git rev-parse --show-toplevel) || return 1
    git secret hide -vmF
    cd -
}

switch() {
    # 1. Get Git Root
    local git_root
    if ! git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
        echo "Error: Not inside a git repository."
        return 1
    fi

    local current_dir="$(pwd)"
    
    # 2. Define your environment containers (Order matters for default fallback)
    local candidates=("infra" "overlays")
    local base_dir_name=""

    # 3. Smart Scope Detection: check if we are *inside* a specific container
    for cand in "${candidates[@]}"; do
        if [[ "$current_dir" == "$git_root/$cand"* ]]; then
            base_dir_name="$cand"
            break
        fi
    done

    # 4. Fallback: If at repo root, default to the first candidate that exists
    if [ -z "$base_dir_name" ]; then
        for cand in "${candidates[@]}"; do
            if [ -d "$git_root/$cand" ]; then
                base_dir_name="$cand"
                break
            fi
        done
    fi

    if [ -z "$base_dir_name" ]; then
        echo "Error: Could not find 'infra' or 'overlays' directories."
        return 1
    fi

    local base_path="$git_root/$base_dir_name"

    # 5. Select Target Environment (Scoped to the detected base directory)
    local envs
    envs=$(find "$base_path" -mindepth 1 -maxdepth 1 -type d -not -name '.*' -exec basename {} \;)
    
    local target_env
    target_env=$(echo "$envs" | fzf --height=~50% --header="Switching inside: $base_dir_name")

    if [ -z "$target_env" ]; then
        return 0
    fi

    # 6. Construct Target Path (Preserve subdirectory depth)
    local target_full_path

    if [[ "$current_dir" == "$base_path"* ]]; then
        # We are inside the structure (e.g. .../overlays/dev/clusters)
        
        # Strip the base path to get relative path (e.g. dev/clusters)
        local rel_path="${current_dir#$base_path/}"
        
        # Extract the current environment name (the first segment, e.g. dev)
        local current_env_segment="${rel_path%%/*}"
        
        # Extract the rest of the path (e.g. /clusters)
        # If we are at the env root, this might be empty
        local rest_of_path="${rel_path#$current_env_segment}"
        
        target_full_path="$base_path/$target_env$rest_of_path"
    else
        # We are outside (e.g. at git root), just go to the env root
        target_full_path="$base_path/$target_env"
    fi

    # 7. Execute Switch
    if [ -d "$target_full_path" ]; then
        cd "$target_full_path" || return 1
    else
        echo "Path '$target_full_path' does not exist."
        echo "Falling back to environment root..."
        cd "$base_path/$target_env" || return 1
    fi

    echo "Switched to: $(pwd)"
}


home() {
  pwd
  echo "cd ->"
  cd `git rev-parse --show-toplevel`
  pwd
}
#clamav
scandir() {
  # check first argument
  # if empty, scan current directory
  # if not empty, scan that directory
  RECURSIVE=""
  if [ -z "$1" ]
  then
    location=$(pwd)
  else
    location=$1
  fi
  # check second argument equals r, then scan recursively
  if [ "$2" = "r" ]
  then
    echo "recursive"
    RECURSIVE="-r"
  fi
    echo "start scanning $location"
    echo "docker run -it --rm \
    --mount type=bind,source=$location,target=/scandir \
    clamav/clamav:unstable \
    clamscan /scandir $RECURSIVE"
    docker run -it --rm \
    --mount type=bind,source=$location,target=/scandir \
    clamav/clamav:unstable \
    clamscan /scandir $RECURSIVE
}

