{
  "layer": "top",
  "position": "top",
  "height": 80,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["tray", "mpris"],
  "modules-right": ["custom/weather", "pulseaudio", "upower", "clock"],
  "hyprland/workspaces": {
    "format": "{id} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "",
    "window-rewrite": {
      "class<Alacritty>": "",
      "class<firefox>": "¾░ł╣",
      "class<Brave-browser>": "¾░¢¤",
      "class<brave-browser-beta>": "¾░¢¤",
      "class<brave-gemini.google.com__-Default>": "",
      "class<thunderbird>": "¾░ć«",
      "class<thunar>": "¾░ēŗ",
      "class<code-insiders>": "¾░©×",
      "class<code>": "¾░©×",
      "class<Code>": "¾░©×",
      "class<Spotify>": "¾░ōć",
      "class<discord>": "¾░Ö»",
      "class<slack>": "¾░Æ▒",
      "class<virt-manager>": "¾░ó╣",
      "class<pavucontrol>": "¾░ĢŠ"
    }
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "separate-outputs": true
  },
  "mpris": {
    "format": "{player_icon} {title} - {artist}",
    "format-paused": "{player_icon} {status_icon} {title} - {artist}",
    "format-stopped": "No media",
    "player-icons": {
      "default": "Ō¢Č",
      "spotify": "¾░ōć",
      "firefox": "¾░ł╣",
      "brave": "¾░¢¤"
    },
    "status-icons": {
      "paused": "ŌÅĖ"
    },
    "max-length": 40
  },
  "tray": {
    "icon-size": 36,
    "spacing": 14,
    "show-passive-items": true
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "¾░Ø¤",
    "format-icons": {
      "headphone": "",
      "default": ["", "", "¾░ĢŠ"]
    },
    "scroll-step": 1,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },
  "upower": {
    "format": "{percentage}",
    "format-alt": "{time}",
    "format-plugged": "{percentage}% ",
    "format-low": "{percentage}% ",
    "critical-threshold": 20,
    "low-threshold": 50,
    "format-icons": {
      "default": ["", "", "", "", ""]
    },
    "icon-size": 36,
    "hide-if-empty": true,
    "tooltip": true,
    "update-interval": 10
  },
  "custom/weather": {
    "exec": "curl -sf 'wttr.in/?format=%c+%t' 2>/dev/null || echo '? N/A'",
    "interval": 600,
    "format": "{}",
    "on-click": "eww open --toggle weather-popup"
  },
  "clock": {
    "format": "{:%I:%M %p ŌĆó %a, %d/%m}",
    "format-alt": "{:%Y %B %d %A (%R)}",
    "on-click-middle": "eww open --toggle clock-popup",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "months",
      "mode-mon-col": 3,
      "weeks-pos": "center",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffa066'><b>{}</b></span>",
        "days": "<span color='#dcd7ba'><b>{}</b></span>",
        "weeks": "<span color='#76946a'><b>W{}</b></span>",
        "weekdays": "<span color='#c0a36e'><b>{}</b></span>",
        "today": "<span color='#c34043'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode"
    }
  }
}
