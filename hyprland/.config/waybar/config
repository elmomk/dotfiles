{
  "layer": "top",
  "position": "top",
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["cpu","memory","backlight","clock"],
  "modules-right": ["tray","pulseaudio","upower","custom/wlogout"],
  "hyprland/workspaces": {
    "format": "{id} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "",
    "window-rewrite": {
      "class<Alacritty>": "",
      "class<firefox>": "≤░Ι╣",
      "class<Brave-browser>": "≤░Ψθ",
      "class<brave-browser-beta>": "≤░Ψθ",
      "class<brave-gemini.google.com__-Default>": "",
      "class<thunderbird>": "≤░Θχ",
      "class<thunar>": "≤░ΚΜ",
      "class<code-insiders>": "≤░ρη",
      "class<code>": "≤░ρη",
      "class<Code>": "≤░ρη",
      "class<Spotify>": "≤░ΥΘ",
      "class<discord>": "≤░βψ",
      "class<slack>": "≤░Τ▒",
      "class<virt-manager>": "≤░λ╣",
      "class<pavucontrol>": "≤░Χ╛"
    }
  },
  "clock": {
    "format": "{:%H:%M} ΎΑΩ ",
    "format-alt": "ΎΑΩ {:%Y %B %d %A (%R)}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
                "mode"          : "months",
                "mode-mon-col"  : 3,
                "weeks-pos"     : "center",
                "on-scroll"     : 1,
                "format": {
                          "months":     "<span color='#ffead3'><b>{}</b></span>",
                          "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                          "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                          "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                          "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                          }
                },
    "actions":  {
                "on-click-right": "mode",
                }
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["ΎΗΖ", "ΎΕΣ"],
    "device": "intel_backlight"
},
  "cpu": {
    "format": "ΎΜδ {usage}%",
    "format-alt": "ΎΜδ {load_average}",
    "tooltip-format": "CPU Usage: {usage}%",
    "tooltip-format-alt": "Load Average: {load_average}",
    "interval": 5
},
  "memory": {
    "format-alt": "ΎΔΚ {used:0.1f}G ({swapUsed:0.1f}G)",
    "format": "ΎΔΚ {percentage}% ({swapPercentage}%)",
    "tooltip-format": "Used: {used:0.1f}G / Total: {total:0.1f}G\nSwap: {swapUsed}G/{swapTotal}G",
    "interval": 5
    },
  "pulseaudio": {
    "format": "<span color='#b4befe'>{icon}</span> {volume}%",
    "format-muted": "ΎΑο",
    "tooltip": false,
    "format-icons": {
      "headphone": "ΎΑξ",
      "default": ["ΎΑο", "ΎΑπ", "≤░Χ╛", "≤░Χ╛", "≤░Χ╛", "ΎΑρ", "ΎΑρ", "ΎΑρ"]
    },
    "scroll-step": 1,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pactl set-sink-volume @DEFAULT_SINK@ 50%"
  },
  "tray": {
    "icon-size": 61,
    "spacing": 20,
    "show-passive-items": true
  },
  "upower": {
    "format": "{percentage}",
    "format-alt": "{time}",
    "format-plugged": "{percentage}% ΎΔπ",
    "format-low": "{percentage}% ΎΚΒ",
    "critical-threshold": 20,
    "low-threshold": 50,
    "format-icons": {
      "default": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "icon-size": 60,
    "hide-if-empty": true,
    "tooltip": true,
    "tooltip-spacing": 20,
    "update-interval": 10
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 64,
    "icon-theme": "Numix-Circle",
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  "custom/wlogout": {
    "format": "ΎΑΣ",
    "on-click": "wlogout"
  }
}
