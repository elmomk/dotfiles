{
  "profiles": [
    {
      "name": "workstation-4k",
      "match": { "min_width": 3840 },
      "monitor_template": "{name}, {width}x{height}@{rate}, auto, 1",
      "qs_scales": { "rounding": 2, "spacing": 2, "padding": 2, "font_size": 2 }
    },
    {
      "name": "laptop-1080p",
      "match": { "max_width": 1920 },
      "monitor_template": "{name}, {width}x{height}@{rate}, auto, 1",
      "qs_scales": { "rounding": 1, "spacing": 1, "padding": 1, "font_size": 1 }
    },
    {
      "name": "default",
      "match": {},
      "monitor_template": "{name}, preferred, auto, auto",
      "qs_scales": { "rounding": 1.5, "spacing": 1.5, "padding": 1.5, "font_size": 1.5 }
    }
  ]
}
